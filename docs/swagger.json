{
    "swagger": "2.0",
    "info": {
        "description": "This is a sophisticated league simulation API with Monte Carlo predictions and Time Machine rollback.",
        "title": "Football League Simulation API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/league/next-week": {
            "post": {
                "description": "Simulates the next week's matches and updates state",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "league"
                ],
                "summary": "Simulate next week",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/league/play-all": {
            "post": {
                "description": "Simulates all remaining matches in the season",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "league"
                ],
                "summary": "Play all remaining weeks",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/league/reset": {
            "post": {
                "description": "Resets the entire league to initial state",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "league"
                ],
                "summary": "Reset league",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/league/rollback/{week}": {
            "post": {
                "description": "Reverts database state to a specific week",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "league"
                ],
                "summary": "Time Machine rollback",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Week to rollback to",
                        "name": "week",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/league/table": {
            "get": {
                "description": "Returns current league standings (PTS, W, D, L, GD)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "league"
                ],
                "summary": "Get current standings",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/matches/{id}": {
            "put": {
                "description": "Edits a specific match result; recalculates standings and morale",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "matches"
                ],
                "summary": "Edit match result",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Match ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Scores: {home_score: 1, away_score: 2}",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "integer"
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/simulation/oracle": {
            "get": {
                "description": "Runs 1,000 Monte Carlo simulations to calculate Championship Win %",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "simulation"
                ],
                "summary": "Monte Carlo predictions",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/teams/{id}/metrics": {
            "get": {
                "description": "Returns a team's current Strength, Morale, Fatigue, and Market Value",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "teams"
                ],
                "summary": "Get team metrics",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Team ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.TeamMetrics"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.TeamMetrics": {
            "type": "object",
            "properties": {
                "base_strength": {
                    "type": "integer"
                },
                "city": {
                    "type": "string"
                },
                "current_strength": {
                    "type": "integer"
                },
                "fatigue": {
                    "type": "number"
                },
                "market_value": {
                    "type": "number"
                },
                "morale": {
                    "type": "number"
                },
                "team_id": {
                    "type": "integer"
                },
                "team_name": {
                    "type": "string"
                }
            }
        }
    }
}