# HTTP server port.
PORT=8080

# SQLite database path.
DB_PATH=./league.db

# Optional deterministic seed for repeatable local demos.
# Leave empty for non-deterministic simulation.
SIM_SEED=42

# Weather source for match simulation.
# local is deterministic/offline-friendly; open-meteo calls https://api.open-meteo.com with local fallback.
WEATHER_PROVIDER=local

# Team strength source for simulation.
# local uses seeded strengths, market-value derives strength from local market values,
# transfermarkt calls a self-hosted Transfermarkt-compatible API with local fallback.
TEAM_STRENGTH_PROVIDER=local
TRANSFERMARKT_API_BASE_URL=
